# ---------------------------------------------------------------------------
# HashLens environment configuration
# ---------------------------------------------------------------------------
# Copy to `.env.local` and fill in. NEVER commit a real `.env*` file.
#
# Only VITE_-prefixed values are exposed to the browser bundle. The Supabase
# anon key is a PUBLIC key and is safe to ship to the client — all data access
# is gated by Row Level Security on the server. Do NOT place the service_role
# key here or anywhere in the frontend.
#
# If these are left unset, HashLens runs in LOCAL-ONLY demo mode: cases are
# stored in the browser's localStorage and no network calls are made. This is
# useful for evaluation but is NOT secure multi-user storage.
# ---------------------------------------------------------------------------

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: label shown in the UI header (e.g. "Staging", "Prod").
VITE_ENV_LABEL=local
